<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false">
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
  <property name="LOG_PATTERN"
            value="%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m | %mdc %n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

  <springProperty scope="context" name="app" source="spring.application.name"/>

  <!-- Plain text appender for local dev -->
  <appender name="consoleAppender" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
    </encoder>
  </appender>

  <!-- JSON appender for non-local environments -->
  <appender name="jsonConsoleAppender" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
  </appender>

  <logger name="uk.gov.justice.digital.hmpps.esupervisionapi.AppKt" level="DEBUG"/>
  <logger name="uk.gov.justice.digital.hmpps" level="DEBUG"/>
  <logger name="org.springframework" level="INFO"/>
  <logger name="com.microsoft.applicationinsights" level="INFO"/>
  <logger name="org.apache.catalina" level="INFO"/>
  <logger name="org.springframework.boot" level="INFO"/>

  <springProfile name="local">
    <root level="INFO">
      <appender-ref ref="consoleAppender"/>
    </root>
  </springProfile>

  <springProfile name="!local">
    <root level="INFO">
      <appender-ref ref="jsonConsoleAppender"/>
    </root>
  </springProfile>

</configuration>
